<UserControl
    x:Class="JurysBarManagementSystem.Views.ProductView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="White" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Controls Panel -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <!-- Name -->
            <Grid Width="150" Margin="5">
                <TextBox x:Name="NameBox"
                         GotFocus="TextBox_GotFocus"
                         LostFocus="TextBox_LostFocus"
                         Text="Product Name"/>
                <TextBlock x:Name="NamePlaceholder"
                           Text="Product Name"
                           Foreground="Gray"
                           Margin="5,0,0,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"
                           Visibility="Collapsed"/>
            </Grid>

            <!-- Price -->
            <Grid Width="100" Margin="5">
                <TextBox x:Name="PriceBox"
                         GotFocus="TextBox_GotFocus"
                         LostFocus="TextBox_LostFocus"
                         Text="Price"/>
                <TextBlock x:Name="PricePlaceholder"
                           Text="Price"
                           Foreground="Gray"
                           Margin="5,0,0,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"
                           Visibility="Collapsed"/>
            </Grid>

            <!-- Stock -->
            <Grid Width="100" Margin="5">
                <TextBox x:Name="StockBox"
                         GotFocus="TextBox_GotFocus"
                         LostFocus="TextBox_LostFocus"
                         Text="Stock"/>
                <TextBlock x:Name="StockPlaceholder"
                           Text="Stock"
                           Foreground="Gray"
                           Margin="5,0,0,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"
                           Visibility="Collapsed"/>
            </Grid>

            <Button x:Name="AddProductButton"
                    Content="Add Product"
                    Click="AddProduct_Click"
                    Margin="5"/>
        </StackPanel>

        <!-- Products DataGrid -->
        <DataGrid x:Name="ProductGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Height="400">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="100"/>
                <DataGridTextColumn Header="Stock" Binding="{Binding Stock}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>