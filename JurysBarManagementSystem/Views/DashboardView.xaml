<Window x:Class="JurysBarManagementSystem.Views.DashboardView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Jury's Bar"
        Height="650"
        Width="1100"
        WindowStartupLocation="CenterScreen">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <StackPanel Background="#2c3e50">

            <TextBlock Text="JURY'S BAR"
                       Foreground="White"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="10"
                       HorizontalAlignment="Center"/>

            <Button x:Name="DashboardButton"
                    Content="Dashboard"
                    Click="Dashboard_Click"
                    Margin="5"/>

            <Button x:Name="ProductsButton"
                    Content="Products"
                    Click="Products_Click"
                    Margin="5"/>

            <Button x:Name="SalesButton"
                    Content="Sales"
                    Click="Sales_Click"
                    Margin="5"/>

            <Button x:Name="PayrollButton"
                    Content="Payroll"
                    Click="Payroll_Click"
                    Margin="5"/>

            <Button x:Name="PaymentsButton"
                    Content="Payments"
                    Click="Payments_Click"
                    Margin="5"/>

            <Button x:Name="ReceiptsButton"
                    Content="Receipts"
                    Click="Receipts_Click"
                    Margin="5"/>

            <Button x:Name="UsersButton"
                    Content="Users"
                    Click="Users_Click"
                    Margin="5"/>

            <Button x:Name="TncButton"
                    Content="TNC"
                    Click="Tnc_Click"
                    Margin="5"/>

            <Button x:Name="LogoutButton"
                    Content="Logout"
                    Click="Logout_Click"
                    Margin="5"/>

        </StackPanel>

        <!-- Main Content -->
        <Frame x:Name="MainFrame"
               Grid.Column="1"
               NavigationUIVisibility="Hidden"/>

    </Grid>
    </Window>