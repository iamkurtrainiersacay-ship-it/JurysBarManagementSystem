<Page x:Class="JurysBarManagementSystem.Views.SalesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- PRODUCT LIST -->
        <DataGrid x:Name="ProductsGrid"
                  AutoGenerateColumns="True"
                  Margin="0,0,10,0"/>

        <!-- ORDER PANEL -->
        <StackPanel Grid.Column="1">

            <TextBlock Text="Order Panel"
                       FontSize="18"
                       Margin="10"/>

            <!-- Customer Name -->
            <TextBox x:Name="CustomerBox"
                     Margin="10"
                     Height="30"
                     Padding="5"
                     Text="Customer Name"
                     Foreground="Gray"
                     GotFocus="CustomerBox_GotFocus"
                     LostFocus="CustomerBox_LostFocus"/>

            <!-- Quantity -->
            <TextBox x:Name="QuantityBox"
                     Margin="10"
                     Text="1"/>

            <Button Content="Add Item"
                    Click="AddItem_Click"
                    Margin="10"/>

            <!-- Order Items -->
            <DataGrid x:Name="OrderGrid"
                      Height="200"
                      Margin="10"
                      AutoGenerateColumns="True"/>

            <Button Content="Process Order"
                    Click="ProcessOrder_Click"
                    Margin="10"/>

            <!-- Receipt Display -->
            <TextBox x:Name="ReceiptBox"
                     Margin="10"
                     Height="200"
                     IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto"
                     FontFamily="Consolas"/>
        </StackPanel>

    </Grid>
</Page>