<UserControl x:Class="JurysBarManagementSystem.Views.DashboardContentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="White" Margin="20">

        <StackPanel>

            <!-- Dashboard Title -->
            <TextBlock Text="JURYS BAR DASHBOARD"
                       FontSize="28"
                       Foreground="#1E90FF"
                       FontWeight="Bold"
                       Margin="0,0,0,30"/>

            <!-- Analytics Cards -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,20">

                <!-- Total Products Card -->
                <Border Width="200" Height="100" Background="#1E90FF" CornerRadius="10" Margin="0,0,20,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Total Products" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding ProductCount}" Foreground="White" FontSize="22" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Total Sales Today Card -->
                <Border Width="200" Height="100" Background="#28a745" CornerRadius="10" Margin="0,0,20,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Total Sales Today" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalSalesToday, StringFormat=₱{0:N2}}" Foreground="White" FontSize="22" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Customers Served Today Card -->
                <Border Width="200" Height="100" Background="#ffc107" CornerRadius="10" Margin="0,0,20,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Customers Served" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding CustomersServed}" Foreground="White" FontSize="22" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Receipts Card -->
                <Border Width="200" Height="100" Background="#007bff" CornerRadius="10">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Recent Receipts" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding RecentReceipts.Count}" Foreground="White" FontSize="22" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- Recent Transactions Table -->
            <TextBlock Text="Recent Transactions"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#1E90FF"
                       Margin="0,0,0,10"/>

            <DataGrid x:Name="TransactionsGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      Height="200">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*"/>
                    <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=₱{0:N2}}" Width="*"/>
                    <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Recent Receipts Table -->
            <TextBlock Text="Recent Receipts"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#007bff"
                       Margin="0,20,0,10"/>

            <ListBox ItemsSource="{Binding RecentReceipts}" Height="200" FontFamily="Consolas"/>

        </StackPanel>

    </Grid>
</UserControl>